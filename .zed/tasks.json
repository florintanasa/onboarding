[
	{
		"label": "Jmix 🚀 Clean & Run App",
		"command": "./gradlew clean bootRun",
		// This command starts the application and executes Liquibase migrations.
		"use_new_terminal": false,
		"allow_concurrent_runs": false,
	},
	{
		"label": "Jmix 🧹 Full Clean & Build",
		"command": "./gradlew clean build -x test",
		// This command is equivalent to compiling.
		"use_new_terminal": false,
		"allow_concurrent_runs": false,
	},
]
